@model IEnumerable<BLL.DTOs.DesignServiceDTO>
@{
    ViewData["Title"] = "Наші послуги";
}

<div class="mb-4 mt-3">
    <h2 class="text-primary">Студія Дизайну</h2>
    <p class="text-muted">Ознайомтеся з нашими послугами або замовте дизайн "під ключ".</p>
</div>

<div class="table-responsive rounded border mb-4">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-primary">
            <tr>
                <th class="py-2 px-3">Послуга</th>
                <th class="py-2 px-3">Опис</th>
                <th class="py-2 px-3">Базова вартість</th>
                <th class="py-2 px-3 text-center">Тип</th>
            </tr>
        </thead>
        <tbody class="bg-white">
            @foreach (var item in Model)
            {
                <tr>
                    <td class="py-2 px-3 fw-semibold">@item.Name</td>
                    <td class="py-2 px-3 text-muted">@item.Description</td>
                    <td class="py-2 px-3 text-success">@(item.IsCustom ? "Договірна" : $"{item.BasePrice} грн")</td>
                    <td class="py-2 px-3 text-center">
                        @if (item.IsCustom)
                        {
                            <span class="badge bg-warning text-dark rounded">Під ключ</span>
                        }
                        else
                        {
                            <span class="badge bg-info text-dark rounded">Стандарт</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="mb-4">
    <a asp-controller="Orders" asp-action="Create" class="btn btn-primary rounded">Оформити замовлення</a>
</div>