@model BLL.DTOs.OrderDTO
@{
    ViewData["Title"] = "Оформлення замовлення";
    var services = ViewBag.AvailableServices as IEnumerable<BLL.DTOs.DesignServiceDTO> ?? new List<BLL.DTOs.DesignServiceDTO>();
}

<div class="mt-4 mb-4" style="max-width: 600px;">
    <h3 class="text-primary mb-3">Оформлення замовлення</h3>

    <div class="border rounded p-4 bg-white">
        <form asp-action="Create" asp-controller="Orders" method="post" id="orderForm">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="CustomerName" class="form-label">Ваше ім'я</label>
                <input asp-for="CustomerName" class="form-control rounded" required />
            </div>

            <div class="mb-3">
                <label asp-for="CustomerContact" class="form-label">Контактні дані</label>
                <input asp-for="CustomerContact" class="form-control rounded" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Оберіть послугу</label>

                <input type="hidden" asp-for="IsCustomDesignOrder" id="hiddenIsCustom" value="false" />
                <input type="hidden" asp-for="ServiceName" id="hiddenServiceName" />

                <ul class="nav nav-tabs" id="serviceTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="standard-tab" data-bs-toggle="tab" data-bs-target="#standard-pane" type="button" role="tab">Стандартні послуги</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="custom-tab" data-bs-toggle="tab" data-bs-target="#custom-pane" type="button" role="tab">Під ключ</button>
                    </li>
                </ul>

                <div class="tab-content border border-top-0 rounded-bottom p-3 bg-light" id="serviceTabsContent">

                    <div class="tab-pane fade show active" id="standard-pane" role="tabpanel">
                        <select class="form-select rounded" id="standardSelect">
                            <option value="">Оберіть послугу</option>
                            @foreach (var service in services.Where(s => !s.IsCustom))
                            {
                                <option value="@service.Name">@service.Name (@service.BasePrice грн)</option>
                            }
                        </select>
                    </div>

                    <div class="tab-pane fade" id="custom-pane" role="tabpanel">
                        <select class="form-select rounded" id="customSelect">
                            <option value="">Оберіть послугу</option>
                            @foreach (var service in services.Where(s => s.IsCustom))
                            {
                                <option value="@service.Name">@service.Name (Договірна)</option>
                            }
                        </select>
                    </div>

                </div>
                <span class="text-danger" id="serviceError"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label">Деталі замовлення (опис)</label>
                <textarea asp-for="Description" class="form-control rounded" rows="3" required></textarea>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary rounded me-2">Підтвердити замовлення</button>
                <a asp-controller="Home" asp-action="Index" class="btn btn-secondary rounded">Скасувати</a>
            </div>
        </form>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const hiddenIsCustom = document.getElementById("hiddenIsCustom");
        const hiddenServiceName = document.getElementById("hiddenServiceName");
        const standardSelect = document.getElementById("standardSelect");
        const customSelect = document.getElementById("customSelect");
        const form = document.getElementById("orderForm");
        const errorSpan = document.getElementById("serviceError");

        function updateHiddenFields() {
            var isCustomActive = document.getElementById('custom-tab').classList.contains('active');

            hiddenIsCustom.value = isCustomActive ? "true" : "false";
            hiddenServiceName.value = isCustomActive ? customSelect.value : standardSelect.value;

            if (hiddenServiceName.value) {
                errorSpan.textContent = "";
            }
        }

        standardSelect.addEventListener("change", updateHiddenFields);
        customSelect.addEventListener("change", updateHiddenFields);

        const tabElements = document.querySelectorAll('button[data-bs-toggle="tab"]');
        tabElements.forEach(function(tab) {
            tab.addEventListener('shown.bs.tab', function () {
                updateHiddenFields();
            });
        });

        form.addEventListener("submit", function(e) {
            updateHiddenFields();
            if (!hiddenServiceName.value) {
                e.preventDefault();
                errorSpan.textContent = "Для замовлення з каталогу необхідно вибрати послугу.";
            }
        });
    });
</script>