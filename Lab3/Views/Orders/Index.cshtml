@model IEnumerable<BLL.DTOs.OrderDTO>
@{
    ViewData["Title"] = "Список замовлень";
}

<div class="d-flex justify-content-between align-items-center mt-3 mb-3">
    <h3 class="text-primary mb-0">Всі замовлення</h3>
</div>

<div class="table-responsive rounded border mb-4">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-primary">
            <tr>
                <th class="py-2 px-3">Ім'я клієнта</th>
                <th class="py-2 px-3">Контакти</th>
                <th class="py-2 px-3">Послуга</th>
                <th class="py-2 px-3">Опис</th>
                <th class="py-2 px-3 text-center">Тип</th>
            </tr>
        </thead>
        <tbody class="bg-white">
            @foreach (var order in Model)
            {
                <tr>
                    <td class="py-2 px-3 fw-semibold">@order.CustomerName</td>
                    <td class="py-2 px-3">@order.CustomerContact</td>
                    <td class="py-2 px-3">@order.ServiceName</td>
                    <td class="py-2 px-3 text-muted">@order.Description</td>
                    <td class="py-2 px-3 text-center">
                        @if (order.IsCustomDesignOrder)
                        {
                            <span class="badge bg-warning text-dark rounded">Під ключ</span>
                        }
                        else
                        {
                            <span class="badge bg-info text-dark rounded">Стандарт</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>